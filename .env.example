# ReelForge Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# API Keys & Credentials
# ============================================
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
GOOGLE_OAUTH_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_SECRET_HERE

# ============================================
# Frontend Configuration
# ============================================
REACT_APP_API_URL=http://43.205.31.160:8000/
REACT_APP_ENV=development

# ============================================
# Backend Configuration
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://43.205.31.160:8000/
WORKERS=4
PORT=8000
HOST=0.0.0.0

# ============================================
# Storage Paths (optional)
# Defaults to ./uploads and ./outputs if not set
# ============================================
# UPLOAD_DIR=/path/to/uploads
# OUTPUT_DIR=/path/to/outputs

# ============================================
# Docker Configuration
# ============================================
COMPOSE_PROJECT_NAME=reelforge
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
